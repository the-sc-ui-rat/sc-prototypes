{
  "name": "@safetyculture/sc-ds-proto",
  "version": "0.1.0",
  "private": true,
  "description": "SafetyCulture Prototype with Design System",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "dev:ds": "ladle serve --stories 'src/{ds,patterns}/**/*.stories.tsx' --port 61001",
    "dev:shell": "ladle serve --stories 'src/shell/**/*.stories.tsx' --port 61002",
    "dev:app": "vite --config app/vite.config.ts",
    "build:app": "vite build --config app/vite.config.ts",
    "preview:app": "vite preview --config app/vite.config.ts",
    "dev": "pnpm dev:app",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@safetyculture/icons-react": "2.6.14",
    "@safetyculture/illustrations-react": "0.9.0",
    "@safetyculture/tailwind-config": "^0.1.2",
    "@tanstack/react-table": "^8.21.3",
    "clsx": "^2.1.1",
    "qrcode.react": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@ladle/react": "^5.1.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.6.3",
    "vite": "^6.3.5"
  },
  "peerDependencies": {
    "react": ">=17"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@swc/core", "esbuild", "msw"]
  }
}
